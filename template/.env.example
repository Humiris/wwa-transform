# Copy this to .env.local and fill in your own keys.
# The MCP endpoint and static pages work WITHOUT these — only the AI chat
# and the voice call need them.

# OpenAI — fallback chat model (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-

# Gemini — primary chat + voice model (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza

# Same key as GEMINI_API_KEY — the Gemini Live voice client reads this name
GOOGLE_GENERATIVE_AI_API_KEY=AIza
